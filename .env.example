# ── Polymarket Auth ──
POLY_PRIVATE_KEY=          # Polygon wallet private key (hex, no 0x prefix)
POLY_ADDRESS=              # Polygon wallet address (0x...)
POLY_API_KEY=              # CLOB API key
POLY_API_SECRET=           # CLOB API secret
POLY_API_PASSPHRASE=       # CLOB API passphrase

# ── Telegram ──
TELEGRAM_BOT_TOKEN=        # From @BotFather
TELEGRAM_CHAT_ID=          # Your chat ID (get from @userinfobot)

# ── Strategy Parameters (defaults, overridable via Telegram) ──
BTC_THRESHOLD_PCT=0.05     # Minimum |BTC delta| to enter (%)
MAX_ASK_PRICE=0.85         # Maximum token ask price to accept
MAX_SPREAD=0.50            # Maximum spread to consider market "active"
BET_SHARES=5               # Number of shares per trade (minimum 5)

# ── Operational ──
DB_PATH=trades.db          # SQLite database path
LOG_LEVEL=info             # Logging level: debug, info, warn, error
DRY_RUN=true               # Start in dry-run mode (no real orders)
